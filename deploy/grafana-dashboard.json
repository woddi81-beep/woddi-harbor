{
  "title": "Woddi Harbor",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate",
      "targets": [{"expr": "sum(rate(harbor_http_requests_total[5m])) by (status)"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "p95 latency",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(harbor_http_request_duration_seconds_bucket[5m])) by (le, path))"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "stat",
      "title": "Errors",
      "targets": [{"expr": "sum(rate(harbor_http_requests_total{status=~\"5..\"}[5m]))"}],
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8}
    },
    {
      "type": "stat",
      "title": "In flight",
      "targets": [{"expr": "sum(harbor_http_requests_in_progress)"}],
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8}
    }
  ]
}
