#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import platform
import time
import uuid
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Any

STARTED_AT = time.time()
PROTOCOL_VERSION = "2024-11-05"
TOOLS = [
    {
        "name": "harbor_echo",
        "description": "Return a supplied message through a Harbor-managed MCP process.",
        "inputSchema": {
            "type": "object",
            "properties": {"message": {"type": "string"}},
            "required": ["message"],
            "additionalProperties": False,
        },
    },
    {
        "name": "harbor_runtime",
        "description": "Return non-sensitive runtime health information for this MCP process.",
        "inputSchema": {"type": "object", "properties": {}, "additionalProperties": False},
    },
]


class McpHandler(BaseHTTPRequestHandler):
    server_version = "harbor-ops-mcp/1.0"

    def do_GET(self) -> None:
        if self.path.rstrip("/") == "/health":
            self._json(HTTPStatus.OK, {"ok": True, "uptime_seconds": round(time.time() - STARTED_AT, 3)})
            return
        self._json(HTTPStatus.NOT_FOUND, {"ok": False, "error": "not_found"})

    def do_POST(self) -> None:
        if self.path.rstrip("/") != "/mcp":
            self._json(HTTPStatus.NOT_FOUND, {"ok": False, "error": "not_found"})
            return
        try:
            length = int(self.headers.get("Content-Length", "0"))
            request = json.loads(self.rfile.read(length) or b"{}")
        except (ValueError, json.JSONDecodeError):
            self._rpc_error(None, -32700, "Parse error")
            return

        request_id = request.get("id")
        method = request.get("method")
        if method == "notifications/initialized":
            self.send_response(HTTPStatus.ACCEPTED)
            self.end_headers()
            return
        if method == "initialize":
            self._rpc_result(
                request_id,
                {
                    "protocolVersion": PROTOCOL_VERSION,
                    "capabilities": {"tools": {"listChanged": False}},
                    "serverInfo": {"name": "harbor-ops-mcp", "version": "1.0.0"},
                },
                session_id=str(uuid.uuid4()),
            )
            return
        if method == "tools/list":
            self._rpc_result(request_id, {"tools": TOOLS})
            return
        if method == "tools/call":
            params = request.get("params") if isinstance(request.get("params"), dict) else {}
            self._call_tool(request_id, str(params.get("name", "")), params.get("arguments"))
            return
        self._rpc_error(request_id, -32601, "Method not found")

    def _call_tool(self, request_id: Any, name: str, raw_arguments: Any) -> None:
        arguments = raw_arguments if isinstance(raw_arguments, dict) else {}
        if name == "harbor_echo":
            message = str(arguments.get("message", "")).strip()
            if not message:
                self._rpc_error(request_id, -32602, "message is required")
                return
            result = {"message": message, "managed_by": "woddi-harbor"}
        elif name == "harbor_runtime":
            result = {
                "ok": True,
                "pid": os.getpid(),
                "python": platform.python_version(),
                "uptime_seconds": round(time.time() - STARTED_AT, 3),
            }
        else:
            self._rpc_error(request_id, -32602, f"Unknown tool: {name}")
            return
        self._rpc_result(
            request_id,
            {
                "content": [{"type": "text", "text": json.dumps(result, ensure_ascii=False)}],
                "structuredContent": result,
                "isError": False,
            },
        )

    def _rpc_result(self, request_id: Any, result: dict[str, Any], *, session_id: str = "") -> None:
        headers = {"mcp-session-id": session_id} if session_id else {}
        self._json(HTTPStatus.OK, {"jsonrpc": "2.0", "id": request_id, "result": result}, headers)

    def _rpc_error(self, request_id: Any, code: int, message: str) -> None:
        self._json(HTTPStatus.OK, {"jsonrpc": "2.0", "id": request_id, "error": {"code": code, "message": message}})

    def _json(self, status: HTTPStatus, payload: dict[str, Any], headers: dict[str, str] | None = None) -> None:
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        for key, value in (headers or {}).items():
            self.send_header(key, value)
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format: str, *args: Any) -> None:
        print(f"{self.address_string()} {format % args}", flush=True)


def main() -> None:
    host = os.getenv("MCP_HOST", "127.0.0.1")
    port = int(os.getenv("MCP_PORT", "61000"))
    print(f"harbor-ops-mcp listening on http://{host}:{port}", flush=True)
    ThreadingHTTPServer((host, port), McpHandler).serve_forever()


if __name__ == "__main__":
    main()
